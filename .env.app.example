# ══════════════════════════════════════════════════════════════════════════════
# TTLeave — App Resource Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# Used by: Next.js app container + NLP sidecar (nlp has no env vars of its own)
#
# LOCAL FULL-STACK DEV:
#   Use the combined .env instead of this file:
#     cp .env.example .env
#     docker compose --profile supabase up -d
#
# COOLIFY (app-only, Supabase is a separate Coolify resource):
#   1. cp .env.app.example .env.app  → fill in values
#   2. Paste contents into your App resource's Environment Variables panel in Coolify
#      (or reference the file if Coolify supports env_file)
#   3. The Supabase resource has its own env panel — see .env.supabase.example
#
# ══════════════════════════════════════════════════════════════════════════════


############################################################
# SUPABASE KEYS
# ⚠️  These values must be IDENTICAL to the matching keys
#     in your Supabase resource (.env.supabase.example).
#     They are JWTs signed with the same JWT_SECRET.
############################################################

# JWT signed with JWT_SECRET, role=anon — safe to expose to the browser.
# ⚠️  Must match ANON_KEY in your Supabase resource env.
ANON_KEY=REPLACE_WITH_GENERATED_JWT

# JWT signed with JWT_SECRET, role=service_role — bypasses Row Level Security.
# NEVER expose to the browser. Server-side / API routes only.
# ⚠️  Must match SERVICE_ROLE_KEY in your Supabase resource env.
SERVICE_ROLE_KEY=REPLACE_WITH_GENERATED_JWT


############################################################
# URLS
# NEXT_PUBLIC_* values are baked into the client JS bundle at build time.
# They must be the final public HTTPS URLs in production.
############################################################

# Browser-facing URL of your Kong API gateway (what users' browsers hit).
# ⚠️  Must match SUPABASE_PUBLIC_URL and API_EXTERNAL_URL in Supabase env.
#
# Coolify:         https://api.masterormain.space  (Kong behind Traefik)
# Local dev:       http://localhost:8001
NEXT_PUBLIC_SUPABASE_URL=https://api.masterormain.space

# Public URL of this Next.js app.
# ⚠️  Must match SITE_URL in your Supabase resource env.
#     GoTrue uses SITE_URL to build auth email redirect links.
#
# Coolify:         https://masterormain.space
# Local dev:       http://localhost:3000
NEXT_PUBLIC_APP_URL=https://masterormain.space


############################################################
# GOOGLE OAUTH (optional — only if you enabled it in Supabase env)
# ⚠️  Must match GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in Supabase env.
############################################################

ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
