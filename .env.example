# ══════════════════════════════════════════════════════════════════════════════
# TTLeave — Self-Hosted Environment Variables
#
# SETUP:
#   1. cp .env.example .env
#   2. bash scripts/generate-secrets.sh   → paste output into this file
#   3. Fill in the URL and SMTP sections below
#   4. docker compose up -d
#
# Never commit .env to git. Add it to .gitignore.
# ══════════════════════════════════════════════════════════════════════════════


############################################################
# SECRETS — Generate these with: bash scripts/generate-secrets.sh
# NEVER use placeholder values in production.
############################################################

# PostgreSQL superuser password — used by all Supabase services that connect to db
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_VALUE

# JWT signing secret — minimum 32 characters — used by Auth, REST, Realtime
JWT_SECRET=REPLACE_WITH_GENERATED_VALUE

# ANON_KEY — a JWT signed with JWT_SECRET, role=anon, 10-year expiry
# Used by the public browser Supabase client (NEXT_PUBLIC_)
ANON_KEY=REPLACE_WITH_GENERATED_JWT

# SERVICE_ROLE_KEY — a JWT signed with JWT_SECRET, role=service_role, 10-year expiry
# Bypasses Row Level Security. Keep server-side only. Never expose to the browser.
SERVICE_ROLE_KEY=REPLACE_WITH_GENERATED_JWT

# Kong dashboard basic-auth credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Realtime secret key base — must be >= 64 random characters
SECRET_KEY_BASE=REPLACE_WITH_GENERATED_VALUE


############################################################
# URLS — Set these to match your deployment environment
############################################################

# The externally reachable URL of the Kong gateway.
# This is what the USER'S BROWSER sends Supabase API requests to.
#
# Examples:
#   Coolify with custom domain:  https://supabase.yourdomain.com
#   VPS direct (no TLS):         http://YOUR_VPS_IP:8001
#   Local development:           http://localhost:8001
SUPABASE_PUBLIC_URL=http://localhost:8001

# Same value as SUPABASE_PUBLIC_URL — used by GoTrue for OAuth callback construction
API_EXTERNAL_URL=http://localhost:8001

# The public URL of the Next.js application — used by GoTrue for auth redirects
SITE_URL=http://localhost:3000

# Comma-separated list of additional allowed OAuth redirect URLs (leave empty if none)
ADDITIONAL_REDIRECT_URLS=


############################################################
# NEXT.JS APP — Public vars (baked into client bundle at build time)
############################################################

# Must equal SUPABASE_PUBLIC_URL — the URL browsers use to reach the Supabase API
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8001

# The externally reachable URL of the Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000


############################################################
# DATABASE
############################################################

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432


############################################################
# AUTH (GoTrue)
############################################################

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# Email
ENABLE_EMAIL_SIGNUP=true
# Set true only for local dev to skip email verification
ENABLE_EMAIL_AUTOCONFIRM=false

# Anonymous users (usually disabled)
ENABLE_ANONYMOUS_USERS=false

# Phone auth
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# GoTrue email path templates (do not change unless you customise GoTrue)
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify


############################################################
# SMTP — Required for email auth (signup confirmation, password reset)
# Use any transactional provider: Resend, Postmark, SES, Mailgun, etc.
############################################################

SMTP_ADMIN_EMAIL=noreply@yourdomain.com
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SENDER_NAME=TTLeave


############################################################
# OAUTH — Social login (optional)
# Register apps at: console.cloud.google.com and github.com/settings/apps
############################################################

ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ENABLE_GITHUB_AUTH=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


############################################################
# REST (PostgREST)
############################################################

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions


############################################################
# KONG (API Gateway)
############################################################
# Default 8001 avoids conflict with Coolify (which often uses 8000).
# Set KONG_HTTP_PORT=8000 if you don't need to avoid 8000.

KONG_HTTP_PORT=8001


############################################################
# STUDIO (Supabase Dashboard — accessible at port 3001)
# Remove the studio service from docker-compose.yml to disable.
############################################################

STUDIO_DEFAULT_ORGANIZATION=TTLeave
STUDIO_DEFAULT_PROJECT=TTLeave


############################################################
# STORAGE
############################################################

IMGPROXY_ENABLE_WEBP_DETECTION=true


############################################################
# ANALYTICS (stub values — only needed if Studio log viewer is enabled)
############################################################

LOGFLARE_PUBLIC_ACCESS_TOKEN=stub
LOGFLARE_PRIVATE_ACCESS_TOKEN=stub
