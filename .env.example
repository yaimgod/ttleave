# ══════════════════════════════════════════════════════════════════════════════
# TTLeave — Combined Environment Variables (local full-stack dev)
# ══════════════════════════════════════════════════════════════════════════════
#
# This file is the COMBINED reference for running the full stack locally:
#   docker compose --profile supabase up -d
#
# For COOLIFY deployment (app and Supabase as separate resources):
#   → App resource vars:      .env.app.example
#   → Supabase resource vars: .env.supabase.example
#
# SETUP:
#   1. cp .env.example .env
#   2. bash scripts/generate-secrets.sh   → paste output into SECRETS below
#   3. Fill in URLS and SMTP sections
#   4. docker compose --profile supabase up -d
#
# Never commit .env to git — it contains secrets.
# ══════════════════════════════════════════════════════════════════════════════


############################################################
# SECRETS
# Generate with: bash scripts/generate-secrets.sh
# NEVER use placeholder values in production.
############################################################

# PostgreSQL superuser password — used by all Supabase services that connect to db.
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_VALUE

# JWT signing secret (min 32 chars) — used by Auth, REST, Realtime.
JWT_SECRET=REPLACE_WITH_GENERATED_VALUE

# ANON_KEY — JWT signed with JWT_SECRET, role=anon, 10-year expiry.
# Used by the browser Supabase client (NEXT_PUBLIC_SUPABASE_ANON_KEY).
# ⚠️  Shared between app and Supabase: same value in both .env.app and .env.supabase.
ANON_KEY=REPLACE_WITH_GENERATED_JWT

# SERVICE_ROLE_KEY — JWT signed with JWT_SECRET, role=service_role, 10-year expiry.
# Bypasses Row Level Security. Server-side only. NEVER expose to browsers.
# ⚠️  Shared between app and Supabase: same value in both .env.app and .env.supabase.
SERVICE_ROLE_KEY=REPLACE_WITH_GENERATED_JWT

# Kong dashboard basic-auth password (username is always "supabase").
DASHBOARD_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Realtime secret key base — must be ≥ 64 random characters.
SECRET_KEY_BASE=REPLACE_WITH_GENERATED_VALUE


############################################################
# URLS
# ⚠️  Cross-file constraints:
#   SUPABASE_PUBLIC_URL == API_EXTERNAL_URL == NEXT_PUBLIC_SUPABASE_URL
#   SITE_URL            == NEXT_PUBLIC_APP_URL
############################################################

# Externally reachable URL of the Kong API gateway (what browsers hit).
# Local dev:       http://localhost:8001
# Coolify/prod:    https://api.masteroradmin.space
SUPABASE_PUBLIC_URL=http://localhost:8001

# Same as SUPABASE_PUBLIC_URL — used by GoTrue for OAuth callback construction.
API_EXTERNAL_URL=http://localhost:8001

# Public URL of the Next.js app — GoTrue uses this for auth email redirect links.
# Local dev:       http://localhost:3000
# Coolify/prod:    https://masteroradmin.space
SITE_URL=http://localhost:3000

# Comma-separated list of additional allowed OAuth redirect URLs (leave empty if none).
ADDITIONAL_REDIRECT_URLS=

# Browser-facing Kong URL baked into the Next.js client bundle at build time.
# ⚠️  Must equal SUPABASE_PUBLIC_URL.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8001

# Public URL of the Next.js app baked into the client bundle.
# ⚠️  Must equal SITE_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000


############################################################
# DATABASE
############################################################

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432


############################################################
# AUTH (GoTrue)
############################################################

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# Email
ENABLE_EMAIL_SIGNUP=true
# Set true only for local dev to skip email verification. NEVER true in production.
ENABLE_EMAIL_AUTOCONFIRM=false

# Anonymous users (recommended: disabled)
ENABLE_ANONYMOUS_USERS=false

# Phone auth (requires Twilio — leave false unless configured)
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# GoTrue email URL path templates — do not change unless you customise GoTrue.
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify


############################################################
# SMTP — GoTrue sends all auth emails (confirm, reset, invite) via this relay.
#
# A real transactional SMTP provider is required (mailpit was removed).
# Recommended: Resend (free tier: 100 emails/day, 3 000/month)
#   1. Sign up at resend.com
#   2. Domains → Add your domain → verify the DNS records shown
#   3. Generate an API key
#   4. Fill in the values below
#
# Other providers: Mailgun, Postmark, Amazon SES, Brevo, etc.
# See .env.supabase.example for the full reference.
############################################################

SMTP_ADMIN_EMAIL=noreply@masteroradmin.space
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_REPLACE_WITH_YOUR_RESEND_API_KEY
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_REPLACE_WITH_YOUR_RESEND_API_KEY
SMTP_SENDER_NAME=TTLeave


############################################################
# OAUTH — Social login (optional)
# ⚠️  ENABLE_GOOGLE_AUTH must match in both .env.app and .env.supabase.
############################################################

ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


############################################################
# REST (PostgREST)
############################################################

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions


############################################################
# KONG (API Gateway)
# Port 8001 avoids Coolify's Traefik which uses 8000.
############################################################

KONG_HTTP_PORT=8001


############################################################
# STUDIO (Supabase Dashboard — http://localhost:3001)
# Username: supabase  Password: DASHBOARD_PASSWORD above
############################################################

STUDIO_DEFAULT_ORGANIZATION=TTLeave
STUDIO_DEFAULT_PROJECT=TTLeave


############################################################
# STORAGE
############################################################

IMGPROXY_ENABLE_WEBP_DETECTION=true


