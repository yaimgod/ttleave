# ══════════════════════════════════════════════════════════════════════════════
# TTLeave — Supabase Resource Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# Used by: db, migrate, kong, auth (GoTrue), rest (PostgREST),
#          realtime, storage, imgproxy, meta, studio
#
# LOCAL FULL-STACK DEV:
#   Use the combined .env instead of this file:
#     cp .env.example .env
#     bash scripts/generate-secrets.sh   → paste output into .env
#     docker compose --profile supabase up -d
#
# COOLIFY (Supabase deployed as its own resource, separate from the app):
#   1. cp .env.supabase.example .env.supabase  → fill in values
#   2. Paste contents into your Supabase resource's Environment Variables panel
#   3. The App resource has its own env panel — see .env.app.example
#
# GENERATE SECRETS:
#   bash scripts/generate-secrets.sh
#   Paste the output into the SECRETS section below.
#
# ══════════════════════════════════════════════════════════════════════════════


############################################################
# SECRETS
# Generate with: bash scripts/generate-secrets.sh
# NEVER use placeholder values in production.
############################################################

# PostgreSQL superuser password — used by every service that connects to db.
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_VALUE

# JWT signing secret (min 32 chars) — used by Auth, REST, Realtime.
# ANON_KEY and SERVICE_ROLE_KEY are JWTs signed with this secret.
JWT_SECRET=REPLACE_WITH_GENERATED_VALUE

# JWT signed with JWT_SECRET, role=anon, 10-year expiry.
# ⚠️  Must match ANON_KEY in your App resource env (.env.app.example).
ANON_KEY=REPLACE_WITH_GENERATED_JWT

# JWT signed with JWT_SECRET, role=service_role, 10-year expiry.
# Bypasses Row Level Security — NEVER expose to browsers.
# ⚠️  Must match SERVICE_ROLE_KEY in your App resource env (.env.app.example).
SERVICE_ROLE_KEY=REPLACE_WITH_GENERATED_JWT

# Kong dashboard basic-auth password. Username is always "supabase".
DASHBOARD_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Realtime secret key base — must be ≥ 64 random characters.
SECRET_KEY_BASE=REPLACE_WITH_GENERATED_VALUE


############################################################
# URLS
############################################################

# Externally reachable URL of the Kong API gateway.
# This is what browsers send Supabase API requests to.
# ⚠️  Must match NEXT_PUBLIC_SUPABASE_URL in your App resource env.
#
# Coolify:         https://api.masteroradmin.space  (Kong behind Traefik)
# Local dev:       http://localhost:8001
SUPABASE_PUBLIC_URL=https://api.masteroradmin.space

# Same as SUPABASE_PUBLIC_URL — used by GoTrue for OAuth callback construction.
# ⚠️  Must always equal SUPABASE_PUBLIC_URL.
API_EXTERNAL_URL=https://api.masteroradmin.space

# Public URL of the Next.js app — GoTrue uses this for auth email redirect links.
# ⚠️  Must match NEXT_PUBLIC_APP_URL in your App resource env.
#
# Coolify:         https://masteroradmin.space
# Local dev:       http://localhost:3000
SITE_URL=https://masteroradmin.space

# Comma-separated list of additional allowed OAuth redirect URLs.
# Add any extra domains/paths you want GoTrue to allow redirects to.
ADDITIONAL_REDIRECT_URLS=


############################################################
# DATABASE
############################################################

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432


############################################################
# AUTH (GoTrue)
############################################################

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# Email
ENABLE_EMAIL_SIGNUP=true
# Set true only for local dev to skip email verification. NEVER true in production.
ENABLE_EMAIL_AUTOCONFIRM=false

# Anonymous users (recommended: disabled)
ENABLE_ANONYMOUS_USERS=false

# Phone auth (requires Twilio or similar — leave false unless configured)
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# GoTrue email URL path templates — do not change unless you customise GoTrue.
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify


############################################################
# SMTP — GoTrue sends all auth emails (confirm, reset, invite) via this relay.
#
# A real transactional SMTP provider is required.
# Recommended: Resend (free tier: 100 emails/day, 3 000/month)
#   1. Sign up at resend.com
#   2. Domains → Add your domain → add the DNS records shown
#   3. Generate an API key
#   4. Fill in the values below
#
# Other providers: Mailgun, Postmark, Amazon SES, Brevo, etc.
#
# Note: mailpit (local mail catcher) has been removed from this stack.
# Use ENABLE_EMAIL_AUTOCONFIRM=true during local dev to skip email verification,
# and point SMTP_* at a real provider for any environment that sends real mail.
############################################################

SMTP_ADMIN_EMAIL=noreply@masteroradmin.space
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_REPLACE_WITH_YOUR_RESEND_API_KEY
SMTP_SENDER_NAME=TTLeave


############################################################
# OAUTH — Social login (optional)
# ⚠️  ENABLE_GOOGLE_AUTH must match the value in your App resource env.
# Register apps at: console.cloud.google.com
############################################################

ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


############################################################
# REST (PostgREST)
############################################################

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions


############################################################
# KONG (API Gateway)
#
# Host port 8001 — avoids 8000 which Coolify's Traefik dashboard uses.
# In production behind Coolify/Traefik: Traefik routes to Kong internally
# so port 8001 does NOT need to be open in the VPS firewall.
# Only open 8001 to the internet if you are NOT using a reverse proxy.
############################################################

KONG_HTTP_PORT=8001


############################################################
# STUDIO (Supabase Dashboard)
#
# Bound to 127.0.0.1:3001 — NOT exposed to the internet.
# Access options:
#   1. SSH tunnel:  ssh -L 3001:localhost:3001 user@your-vps  → open http://localhost:3001
#   2. Via Kong:    http://your-vps:8001/dashboard  (basic-auth: supabase / DASHBOARD_PASSWORD)
#
# Never expose 3001 to the internet — no TLS, no rate limiting.
############################################################

STUDIO_DEFAULT_ORGANIZATION=TTLeave
STUDIO_DEFAULT_PROJECT=TTLeave


############################################################
# STORAGE
############################################################

IMGPROXY_AUTO_WEBP=true


